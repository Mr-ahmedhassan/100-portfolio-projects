                <zone forceUpdate='true' h='29556' id='32' type-v2='text' w='15250' x='2125' y='29778'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#00ffff' fontname='Bookman Old Style' fontsize='14' underline='true'>Hours</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Bookman Old Style' fontsize='13' italic='true'>Peak Orders are </run>
                    <run bold='true' fontalignment='1' fontcolor='#f9a655' fontname='Bookman Old Style' fontsize='13' italic='true'>between 12:00 PM and 1:00 PM</run>
                    <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Bookman Old Style' fontsize='13' italic='true'>, and in the evening</run>
                    <run bold='true' fontalignment='1' fontcolor='#f9a655' fontname='Bookman Old Style' fontsize='13' italic='true'> from 4:00 PM to 7:00 PM</run>
                    <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Bookman Old Style' fontsize='13' italic='true'>.</run>
                    <run fontalignment='1'>Æ&#10;&#10;</run>
                    <run bold='true' fontalignment='1' fontcolor='#00ffff' fontname='Bookman Old Style' fontsize='14' underline='true'>Weeks</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run bold='true' fontalignment='1' fontcolor='#f9a655' fontname='Bookman Old Style' fontsize='13' italic='true'>Significant variation in weekly orders,</run>
                    <run bold='true' fontalignment='1' fontcolor='#00ffff' fontname='Bookman Old Style' fontsize='13' italic='true'>Æ </run>
                    <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Bookman Old Style' fontsize='13' italic='true'>with the highest peak during </run>
                    <run bold='true' fontalignment='1' fontcolor='#f9a655' fontname='Bookman Old Style' fontsize='13' italic='true'>the 48th week</run>
                    <run bold='true' fontalignment='1' fontcolor='#00ffff' fontname='Bookman Old Style' fontsize='13' italic='true'>Æ </run>
                    <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Bookman Old Style' fontsize='13' italic='true'>of the</run>
                    <run bold='true' fontalignment='1' fontcolor='#00ffff' fontname='Bookman Old Style' fontsize='13' italic='true'>Æ </run>
                    <run bold='true' fontalignment='1' fontcolor='#f9a655' fontname='Bookman Old Style' fontsize='13' italic='true'>month of DEC</run>
                    <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Bookman Old Style' fontsize='13' italic='true'>.</run>
                  </formatted-text>
